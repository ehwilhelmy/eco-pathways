# Copy this file to `.env.local` and fill in your value.

# Resend API key — powers the Request Estimate form (sends submissions by email).
# 1. Sign up at https://resend.com using fhopf47@gmail.com (the inbox that
#    should receive estimate requests).
# 2. Go to API Keys → Create API Key → copy it.
# 3. Paste it below (server-side only — never prefixed with NEXT_PUBLIC).
# Submissions are delivered to fhopf47@gmail.com (set in app/api/estimate/route.ts).
RESEND_API_KEY=
